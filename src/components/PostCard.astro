---
import { CATEGORY_NAMES } from '../data/categories.js';

const { href, title, description, category, pubDate, variant = 'list', metric } = Astro.props;

const catName = CATEGORY_NAMES;
const dateStr = new Date(pubDate).toLocaleDateString('ko-KR', {
  year: 'numeric', month: 'short', day: 'numeric',
});
const shortDateStr = (() => {
  const d = new Date(pubDate);
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  const dd = String(d.getDate()).padStart(2, '0');
  return `${mm}.${dd}`;
})();

// NEW 배지: 발행일(pubDate) 기준 7일간(발행 당일 포함) 자동으로 붙는다.
// 시:분까지 비교하면 발행 시각에 따라 7일째 중간에 사라지는 문제가 생기므로,
// 날짜(자정 기준)만 비교해 "발행일로부터 며칠째인지"를 정수로 계산한다.
// contentTags의 "new"(신설·변경 여부, 영구적 분류)와는 별개 축 —
// "이 글이 최근에 올라왔다"는 신선도 표시라 시간이 지나면 자동으로 사라진다.
const NEW_BADGE_DAYS = 7;
const isNew = (() => {
  const startOfDay = (d) => {
    const x = new Date(d);
    x.setHours(0, 0, 0, 0);
    return x;
  };
  const diffDays = Math.floor((startOfDay(new Date()) - startOfDay(pubDate)) / (1000 * 60 * 60 * 24));
  return diffDays >= 0 && diffDays <= NEW_BADGE_DAYS;
})();
---

{variant === 'card' ? (
  <a href={href} class="post-card">
    <div class="post-card-top">
      <span class="cat-badge" data-cat={category}>{catName[category]}</span>
      {isNew && <span class="new-badge">NEW</span>}
      <span class="post-date">{shortDateStr}</span>
    </div>
    <h3 class="post-title">{title}</h3>
    <p class="post-desc">{description}</p>
  </a>
) : (
  <a href={href} class="list-row">
    <span class="list-date">{shortDateStr}</span>
    <span class="list-body">
      <span class="list-title-row">
        {isNew && <span class="new-badge">NEW</span>}
        <span class="list-title">{title}</span>
      </span>
      <span class="list-desc">{description}</span>
    </span>
    {metric && <span class="list-metric">{metric}</span>}
  </a>
)}

<style>
  /* ── 리스트형 (카테고리 페이지 등) ── */
  .list-row {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.1rem 0; border-bottom: 1px solid var(--line);
    text-decoration: none; color: inherit;
    transition: transform 0.15s;
  }
  .list-row:hover { transform: translateX(4px); }
  .list-row:last-child { border-bottom: none; padding-bottom: 0; }
  .list-row:hover .list-title { color: var(--primary); }
  .list-date { flex-shrink: 0; width: 2.7rem; font-size: 0.78rem; color: var(--muted); }
  .list-body { flex: 1; min-width: 0; }
  .list-title-row { display: flex; align-items: center; gap: 0.45rem; margin-bottom: 0.25rem; }
  .list-title { font-size: 1.05rem; font-weight: 700; color: var(--ink); transition: color 0.15s; }
  .list-desc { display: block; font-size: 0.88rem; color: var(--muted); line-height: 1.5; }
  .list-metric { flex-shrink: 0; font-size: 0.88rem; font-weight: 700; color: var(--accent); white-space: nowrap; }

  /* ── 카드형 (홈 최신 글 그리드) ── */
  .post-card {
    display: flex; flex-direction: column; gap: 0.85rem;
    text-decoration: none; color: inherit;
    padding: 1.5rem 1.6rem;
    border: 1px solid var(--line); border-radius: 12px;
    background: #fff;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .post-card:hover { border-color: var(--primary); transform: translateY(-2px); box-shadow: 0 8px 20px rgba(30, 58, 95, 0.08); }
  .post-card-top { display: flex; align-items: center; gap: 0.5rem; }
  .cat-badge {
    font-size: 0.74rem; font-weight: 700; padding: 0.22rem 0.65rem;
    border-radius: 20px; background: var(--color-bg-soft); color: var(--primary);
  }
  .cat-badge[data-cat="parenting"] { background: #fce7f3; color: #9d174d; }
  .cat-badge[data-cat="senior"] { background: #ede9fe; color: #5b21b6; }
  .cat-badge[data-cat="housing"] { background: #dcfce7; color: #166534; }
  .cat-badge[data-cat="youth"] { background: #dbeafe; color: #1e40af; }
  .cat-badge[data-cat="job-startup"] { background: #fef3c7; color: #92400e; }
  .cat-badge[data-cat="common"] { background: #e0e7ff; color: #3730a3; }
  .cat-badge[data-cat="self-employed"] { background: #ffedd5; color: #9a3412; }
  .new-badge {
    flex-shrink: 0;
    font-size: 0.68rem; font-weight: 700; color: #16a34a; background: #f0fdf4;
    padding: 0.16rem 0.5rem; border-radius: 10px;
  }
  .post-date { margin-left: auto; font-size: 0.8rem; color: var(--muted); }
  .post-title { font-size: 1.12rem; font-weight: 700; color: var(--ink); line-height: 1.45; margin: 0; }
  .post-card:hover .post-title { color: var(--primary); }
  .post-desc {
    font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  @media (max-width: 640px) {
    .list-row { gap: 0.6rem; }
    .list-date { width: 2.3rem; font-size: 0.72rem; }
    .list-title { font-size: 0.96rem; }
    .list-metric { font-size: 0.8rem; }
  }
</style>
