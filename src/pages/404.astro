---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="페이지를 찾을 수 없어요 — 혜택 PICK!!"
  description="요청하신 페이지를 찾을 수 없어요. 주소가 바뀌었거나 삭제된 페이지일 수 있어요."
>
  <section class="not-found">
    <img src="/images/hero-squirrel.png" alt="" width="140" height="140" class="nf-img" />
    <h1>이 페이지는 도토리를 못 찾았어요</h1>
    <p>요청하신 주소를 찾을 수 없어요. 주소가 바뀌었거나 삭제된 페이지일 수 있어요.</p>
    <div class="nf-actions">
      <a href="/" class="nf-btn primary">홈으로 가기</a>
      <a href="/find" class="nf-btn">나에게 맞는 혜택 찾기</a>
    </div>
  </section>

  <style>
    .not-found {
      text-align: center; padding: 4rem 0 5rem;
      display: flex; flex-direction: column; align-items: center;
    }
    .nf-img { width: 140px; height: auto; margin-bottom: 1.5rem; opacity: 0.9; }
    .not-found h1 {
      font-size: 1.5rem; font-weight: 800; letter-spacing: -0.02em;
      margin: 0 0 0.6rem; color: var(--ink);
    }
    .not-found p { color: var(--muted); font-size: 0.98rem; margin: 0 0 2rem; }
    .nf-actions { display: flex; gap: 0.7rem; flex-wrap: wrap; justify-content: center; }
    .nf-btn {
      display: inline-flex; align-items: center; font-size: 0.92rem; font-weight: 700;
      padding: 0.65rem 1.3rem; border-radius: 999px; text-decoration: none;
      border: 1px solid var(--line); color: var(--ink); transition: all 0.15s;
    }
    .nf-btn:hover { border-color: var(--primary); color: var(--primary); }
    .nf-btn.primary { background: var(--primary); border-color: var(--primary); color: #fff; }
    .nf-btn.primary:hover { opacity: 0.88; color: #fff; }
  </style>
</BaseLayout>
