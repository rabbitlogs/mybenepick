---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const categoryCount = new Set(allPosts.map((p) => p.data.category)).size;
const latestUpdate = allPosts.reduce((latest, p) => {
  const d = (p.data.updatedDate || p.data.pubDate);
  return d > latest ? d : latest;
}, new Date(0));
const latestUpdateStr = latestUpdate.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\. /g, '.').replace(/\.$/, '');
---

<BaseLayout
  title="혜택PICK!! — 나에게 맞는 혜택만, PICK해서 알려드려요"
  description="새로 생기거나 바뀐 정부 지원금·제도를 대상자별로 정리해드려요. 신청 조건, 방법, 놓치기 쉬운 디테일까지 한 번에 확인하세요."
>
  <section class="hero">
    <div class="hero-text">
      <p class="hero-eyebrow">정부 지원금 · 보조금 정보</p>
      <h1>나에게 맞는 혜택만,<br />PICK해서 알려드려요.</h1>
      <p class="hero-sub">새로 생기거나 바뀐 정부 지원금,<br class="mobile-br" /> 대상자별로 정리해드려요.</p>

      <button type="button" class="hero-search" data-search-open aria-label="지원금 검색">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <span class="hero-search-placeholder">예: 청년 취업, 육아휴직, 소상공인 바우처</span>
        <span class="hero-search-btn">찾아보기</span>
      </button>

      <p class="hero-note">보건복지부·고용노동부·국토교통부 등 정부 공식 발표를 기준으로 정리합니다.</p>
    </div>

    <div class="update-card">
      <p class="update-card-label">이번 달 업데이트</p>
      <div class="update-row">
        <span class="update-row-label">신규·변경 지원금</span>
        <span class="update-row-value">{allPosts.length}건</span>
      </div>
      <div class="update-row">
        <span class="update-row-label">생애주기 카테고리</span>
        <span class="update-row-value">{categoryCount}개</span>
      </div>
      <div class="update-row">
        <span class="update-row-label">최근 업데이트</span>
        <span class="update-row-value accent">{latestUpdateStr}</span>
      </div>
    </div>
  </section>

  <section class="latest">
    <div class="latest-header">
      <h2 class="section-title">최신 글</h2>
      <a href="/find" class="find-link">나에게 맞는 글 찾기 →</a>
    </div>
    {posts.map((post) => (
      <PostCard
        href={`/blog/${post.id.replace('.md', '')}`}
        title={post.data.title}
        description={post.data.description}
        category={post.data.category}
        pubDate={post.data.pubDate}
      />
    ))}
  </section>

  <style>
    .hero {
      display: grid; grid-template-columns: 1.3fr 1fr; gap: 2.5rem;
      align-items: center; padding: 3rem 0 2.5rem; text-align: left;
    }
    .hero-eyebrow { display: inline-flex; align-items: center; gap: 6px; font-size: 0.85rem; font-weight: 700; color: var(--accent); margin: 0 0 0.9rem; }
    .hero-eyebrow::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
    .hero h1 { font-family: var(--font-display); font-weight: 800; font-size: 2.1rem; line-height: 1.35; letter-spacing: -0.02em; margin: 0 0 1rem; color: var(--ink); }
    .hero-sub { font-size: 1.1rem; color: var(--muted); margin: 0 0 1.6rem; }
    .hero-note { font-size: 0.82rem; color: var(--muted); margin: 0.9rem 0 0; }
    .mobile-br { display: none; }

    .hero-search {
      display: flex; align-items: center; gap: 0.7rem;
      width: 100%; padding: 0.85rem 1.1rem;
      background: #fff; border: 1px solid var(--line); border-radius: 10px;
      font-family: inherit; cursor: pointer; text-align: left;
      transition: border-color 0.15s;
    }
    .hero-search:hover { border-color: var(--primary); }
    .hero-search svg { flex-shrink: 0; color: var(--muted); }
    .hero-search-placeholder { flex: 1; font-size: 0.94rem; color: var(--muted); }
    .hero-search-btn {
      flex-shrink: 0; font-size: 0.85rem; font-weight: 700; color: #fff;
      background: var(--primary); padding: 0.5rem 1.1rem; border-radius: 8px;
    }

    .update-card {
      background: var(--paper); border: 1px solid var(--line); border-radius: 14px;
      padding: 1.5rem 1.7rem;
    }
    .update-card-label { font-size: 0.85rem; font-weight: 600; color: var(--muted); margin: 0 0 1.1rem; }
    .update-row {
      display: flex; justify-content: space-between; align-items: baseline;
      padding: 0.7rem 0; border-bottom: 1px solid var(--line);
    }
    .update-row:last-child { border-bottom: none; padding-bottom: 0; }
    .update-row-label { font-size: 0.85rem; color: var(--muted); }
    .update-row-value { font-size: 1.15rem; font-weight: 700; color: var(--primary); }
    .update-row-value.accent { color: var(--accent); font-size: 1rem; }

    .latest-header {
      display: flex; align-items: baseline; justify-content: space-between;
      flex-wrap: wrap; gap: 0.5rem 1rem;
      border-bottom: 2px solid var(--primary); padding-bottom: 0.5rem; margin-bottom: 0.5rem;
    }
    .section-title { font-weight: 800; font-size: 1.1rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin: 0; }
    .find-link { font-size: 0.88rem; font-weight: 600; color: var(--primary); text-decoration: none; white-space: nowrap; }
    .find-link:hover { text-decoration: underline; }

    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; padding: 2.2rem 0 1.8rem; }
    }
    @media (max-width: 640px) {
      .hero h1 { font-size: 1.7rem; }
      .mobile-br { display: inline; }
      .hero-search-placeholder { display: none; }
      .latest-header { justify-content: center; text-align: center; }
    }
  </style>
</BaseLayout>
