---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const categoryCount = new Set(allPosts.map((p) => p.data.category)).size;
const latestUpdate = allPosts.reduce((latest, p) => {
  const d = (p.data.updatedDate || p.data.pubDate);
  return d > latest ? d : latest;
}, new Date(0));
const latestUpdateStr = latestUpdate.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\. /g, '.').replace(/\.$/, '');
---

<BaseLayout
  title="혜택PICK!! — 나에게 맞는 혜택만, PICK해서 알려드려요"
  description="새로 생기거나 바뀐 정부 지원금·제도를 대상자별로 정리해드려요. 신청 조건, 방법, 놓치기 쉬운 디테일까지 한 번에 확인하세요."
>
  <section class="hero">
    <div class="hero-text">
      <p class="hero-eyebrow">정부 지원금 · 보조금 정보</p>
      <h1>나에게 맞는 혜택만,<br />PICK해서 알려드려요.</h1>
      <p class="hero-sub">새로 생기거나 바뀐 정부 지원금을 대상자별로 정리해요.</p>

      <button type="button" class="hero-search" data-search-open aria-label="지원금 검색">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <span class="hero-search-placeholder">예: 청년 취업, 육아휴직</span>
        <span class="hero-search-btn">찾아보기</span>
      </button>

      <p class="hero-note">보건복지부·고용노동부·국토교통부 등 정부 공식 발표를 기준으로 정리합니다.</p>
    </div>

    <div class="update-card">
      <p class="update-card-label">이번 달 업데이트</p>
      <div class="update-row">
        <span class="update-row-label">신규·변경 지원금</span>
        <span class="update-row-value">{allPosts.length}건</span>
      </div>
      <div class="update-row">
        <span class="update-row-label">생애주기 카테고리</span>
        <span class="update-row-value">{categoryCount}개</span>
      </div>
      <div class="update-row">
        <span class="update-row-label">최근 업데이트</span>
        <span class="update-row-value accent">{latestUpdateStr}</span>
      </div>
    </div>
  </section>

  <section class="latest">
    <div class="latest-header">
      <h2 class="section-title">최신 글</h2>
      <a href="/find" class="find-link">나에게 맞는 글 찾기 →</a>
    </div>
    <div class="post-grid">
      {posts.map((post) => (
        <PostCard
          variant="card"
          href={`/blog/${post.id.replace('.md', '')}`}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          pubDate={post.data.pubDate}
        />
      ))}
    </div>
  </section>

  <section class="cat-browse">
    <h2 class="section-title">카테고리별로 찾아보기</h2>
    <div class="cat-grid">
      <a href="/category/youth" class="cat-card tone-blue">
        <p class="cat-card-name">청년</p>
        <p class="cat-card-desc">취업, 창업, 자산형성 지원</p>
      </a>
      <a href="/category/job-startup" class="cat-card tone-teal">
        <p class="cat-card-name">취업·창업</p>
        <p class="cat-card-desc">구직급여, 창업자금, 재취업 지원</p>
      </a>
      <a href="/category/parenting" class="cat-card tone-pink">
        <p class="cat-card-name">육아·출산</p>
        <p class="cat-card-desc">육아휴직, 출산장려금, 돌봄 지원</p>
      </a>
      <a href="/category/housing" class="cat-card tone-green">
        <p class="cat-card-name">주거</p>
        <p class="cat-card-desc">전세자금, 청약, 임대주택 지원</p>
      </a>
      <a href="/category/self-employed" class="cat-card tone-amber">
        <p class="cat-card-name">소상공인</p>
        <p class="cat-card-desc">경영안정자금, 바우처, 세제 지원</p>
      </a>
      <a href="/category/senior" class="cat-card tone-purple">
        <p class="cat-card-name">중장년·시니어</p>
        <p class="cat-card-desc">연금, 재취업, 건강 지원</p>
      </a>
      <a href="/category/common" class="cat-card tone-navy">
        <p class="cat-card-name">전국민 공통</p>
        <p class="cat-card-desc">생계, 통신비, 에너지 지원</p>
      </a>
      <a href="/regional" class="cat-card tone-slate">
        <p class="cat-card-name">지역별</p>
        <p class="cat-card-desc">지자체별 특화 지원제도</p>
      </a>
    </div>
  </section>

  <style>
    .hero {
      display: grid; grid-template-columns: 1.3fr 1fr; gap: 2.5rem;
      align-items: center; padding: 3rem 0 2.5rem; text-align: left;
    }
    .hero-eyebrow { display: inline-flex; align-items: center; gap: 6px; font-size: 0.85rem; font-weight: 700; color: var(--accent); margin: 0 0 0.9rem; }
    .hero-eyebrow::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
    .hero h1 { font-family: var(--font-display); font-weight: 800; font-size: 2.1rem; line-height: 1.35; letter-spacing: -0.02em; margin: 0 0 1rem; color: var(--ink); }
    .hero-sub { font-size: 1.1rem; color: var(--muted); margin: 0 0 1.6rem; }
    .hero-note { font-size: 0.82rem; color: var(--muted); margin: 0.9rem 0 0; }
    .mobile-br { display: none; }

    .hero-search {
      display: flex; align-items: center; gap: 0.7rem;
      width: 100%; padding: 0.85rem 1.1rem;
      background: #fff; border: 1px solid var(--line); border-radius: 10px;
      font-family: inherit; cursor: pointer; text-align: left;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .hero-search:hover, .hero-search:focus-visible {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(30, 58, 95, 0.08);
    }
    .hero-search svg { flex-shrink: 0; color: var(--muted); }
    .hero-search-placeholder { flex: 1; font-size: 0.94rem; color: var(--muted); }
    .hero-search-btn {
      flex-shrink: 0; font-size: 0.85rem; font-weight: 700; color: #fff;
      background: var(--primary); padding: 0.5rem 1.1rem; border-radius: 8px;
    }

    .update-card {
      background: var(--paper); border: 1px solid var(--line); border-radius: 14px;
      padding: 1.5rem 1.7rem;
    }
    .update-card-label { font-size: 0.85rem; font-weight: 600; color: var(--muted); margin: 0 0 1.1rem; }
    .update-row {
      display: flex; justify-content: space-between; align-items: baseline;
      padding: 0.7rem 0; border-bottom: 1px solid var(--line);
    }
    .update-row:last-child { border-bottom: none; padding-bottom: 0; }
    .update-row-label { font-size: 0.85rem; color: var(--muted); }
    .update-row-value { font-size: 1.15rem; font-weight: 700; color: var(--primary); }
    .update-row-value.accent { color: var(--accent); font-size: 1rem; }

    .latest-header {
      display: flex; align-items: baseline; justify-content: space-between;
      flex-wrap: wrap; gap: 0.5rem 1rem;
      border-bottom: 2px solid var(--primary); padding-bottom: 0.5rem; margin-bottom: 1.2rem;
    }
    .post-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.3rem;
    }
    .section-title { font-weight: 800; font-size: 1.1rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin: 0; }
    .find-link { font-size: 0.88rem; font-weight: 600; color: var(--primary); text-decoration: none; white-space: nowrap; }
    .find-link:hover { text-decoration: underline; }

    .cat-browse { margin-top: 3rem; padding-bottom: 1rem; }
    .cat-browse .section-title {
      border-bottom: 2px solid var(--primary); padding-bottom: 0.5rem; margin-bottom: 1.2rem;
    }
    .cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.9rem; }
    .cat-card {
      display: block; text-decoration: none;
      padding: 1.2rem 1.3rem; border-radius: 10px; border: 1px solid var(--line);
      transition: transform 0.15s;
    }
    .cat-card:hover { transform: translateY(-2px); }
    .cat-card-name { font-size: 0.95rem; font-weight: 700; margin: 0 0 0.35rem; }
    .cat-card-desc { font-size: 0.78rem; color: var(--muted); margin: 0; }
    .cat-card.tone-blue { background: #eff6ff; } .cat-card.tone-blue .cat-card-name { color: #1e40af; }
    .cat-card.tone-teal { background: #ecfdf5; } .cat-card.tone-teal .cat-card-name { color: #065f46; }
    .cat-card.tone-pink { background: #fdf2f8; } .cat-card.tone-pink .cat-card-name { color: #9d174d; }
    .cat-card.tone-green { background: #f0fdf4; } .cat-card.tone-green .cat-card-name { color: #166534; }
    .cat-card.tone-amber { background: #fffbeb; } .cat-card.tone-amber .cat-card-name { color: #92400e; }
    .cat-card.tone-purple { background: #f5f3ff; } .cat-card.tone-purple .cat-card-name { color: #5b21b6; }
    .cat-card.tone-navy { background: #eef2ff; } .cat-card.tone-navy .cat-card-name { color: #3730a3; }
    .cat-card.tone-slate { background: #f1f5f9; } .cat-card.tone-slate .cat-card-name { color: #334155; }

    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; padding: 2.2rem 0 1.8rem; }
      .cat-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 640px) {
      .hero h1 { font-size: 1.7rem; }
      .mobile-br { display: inline; }
      .hero-search-placeholder { display: none; }
      .latest-header { justify-content: center; text-align: center; }
      .post-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
