---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout
  title="혜택PICK!! — 나에게 맞는 혜택만, PICK해서 알려드려요"
  description="새로 생기거나 바뀐 정부 지원금·제도를 대상자별로 정리해드려요. 신청 조건, 방법, 놓치기 쉬운 디테일까지 한 번에 확인하세요."
>
  <section class="hero">
    <div class="hero-text">
      <p class="hero-eyebrow">정부 지원금 · 보조금 정보</p>
      <h1>나에게 맞는 혜택만,<br />PICK해서 알려드려요.</h1>
      <p class="hero-sub">새로 생기거나 바뀐 정부 지원금,<br class="mobile-br" /> 대상자별로 정리해드려요.</p>
      <p class="hero-note">보건복지부·고용노동부·국토교통부 등 정부 공식 발표를 기준으로 정리합니다.</p>
    </div>
  </section>

  <section class="latest">
    <div class="latest-header">
      <h2 class="section-title">최신 글</h2>
      <a href="/find" class="find-link">나에게 맞는 글 찾기 →</a>
    </div>
    {posts.map((post) => (
      <PostCard
        href={`/blog/${post.id.replace('.md', '')}`}
        title={post.data.title}
        description={post.data.description}
        category={post.data.category}
        pubDate={post.data.pubDate}
      />
    ))}
  </section>

  <style>
    .hero { padding: 3rem 0 2.5rem; text-align: center; }
    .hero-eyebrow { display: inline-flex; align-items: center; gap: 6px; font-size: 0.85rem; font-weight: 700; color: var(--accent); margin: 0 0 0.9rem; }
    .hero-eyebrow::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
    .hero h1 { font-family: var(--font-display); font-weight: 800; font-size: 2.1rem; line-height: 1.35; letter-spacing: -0.02em; margin: 0 0 1rem; color: var(--ink); }
    .hero-sub { font-size: 1.1rem; color: var(--muted); margin: 0 0 1.4rem; }
    .hero-note { font-size: 0.85rem; color: var(--muted); margin: 0; }
    .mobile-br { display: none; }
    .latest-header {
      display: flex; align-items: baseline; justify-content: space-between;
      flex-wrap: wrap; gap: 0.5rem 1rem;
      border-bottom: 2px solid var(--primary); padding-bottom: 0.5rem; margin-bottom: 0.5rem;
    }
    .section-title { font-weight: 800; font-size: 1.1rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin: 0; }
    .find-link { font-size: 0.88rem; font-weight: 600; color: var(--primary); text-decoration: none; white-space: nowrap; }
    .find-link:hover { text-decoration: underline; }

    @media (max-width: 640px) {
      .hero { padding: 2rem 0 1.5rem; }
      .hero h1 { font-size: 1.7rem; }
      .mobile-br { display: inline; }
      .latest-header { justify-content: center; text-align: center; }
    }
  </style>
</BaseLayout>
