---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import AdSenseList from '../../components/AdSenseList.astro';
import { CATEGORY_NAMES_LONG } from '../../data/categories.js';

// ⚠️ BaseLayout.astro의 ADSENSE_ENABLED와 함께 켜고 끄세요.
const ADSENSE_ENABLED = false;

const POSTS_PER_PAGE = 8;
const CATEGORIES = ['youth', 'job-startup', 'parenting', 'housing', 'self-employed', 'senior', 'common'];

export async function getStaticPaths() {
  const { getCollection } = await import('astro:content');
  const allPosts = await getCollection('blog');
  const cats = ['youth', 'job-startup', 'parenting', 'housing', 'self-employed', 'senior', 'common'];
  const perPage = 8;

  const paths = [];
  for (const cat of cats) {
    const posts = allPosts
      .filter((p) => p.data.category === cat)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    const totalPages = Math.max(1, Math.ceil(posts.length / perPage));

    for (let page = 1; page <= totalPages; page++) {
      paths.push({
        params: { cat, page: page === 1 ? undefined : String(page) },
        props: {
          cat,
          page,
          totalPages,
          posts: posts.slice((page - 1) * perPage, page * perPage),
          total: posts.length,
        },
      });
    }
  }
  return paths;
}

const { cat, page, totalPages, posts, total } = Astro.props;
const catName = CATEGORY_NAMES_LONG;
const catDesc = {
  youth: [
    '청년을 위한 지원금과 제도를 모았어요.',
    '청년내일저축계좌 같은 자산형성, 자격조건과 신청방법을 다룹니다.',
  ],
  'job-startup': [
    '구직, 취업, 창업 준비 관련 지원금과 제도를 모았어요.',
    '국민취업지원제도, 청년·중장년 창업지원금 같은 정보를 다룹니다.',
  ],
  parenting: [
    '육아와 출산 관련 지원금과 제도를 모았어요.',
    '한부모가족 지원, 아동수당, 부모급여 등을 정리합니다.',
  ],
  housing: [
    '전세·월세, 내 집 마련 관련 지원금과 제도를 모았어요.',
    '전세자금대출, 주거급여, LH 임대주택 같은 정보를 다룹니다.',
  ],
  'self-employed': [
    '소상공인·자영업자를 위한 지원금과 제도를 모았어요.',
    '창업 초기 운영자금, 노란우산공제 같은 실질적인 정보를 다룹니다.',
  ],
  senior: [
    '중장년과 시니어를 위한 지원금과 제도를 모았어요.',
    '국민연금, 은퇴 준비, 노후 관련 정책을 다룹니다.',
  ],
  common: [
    '소득이나 나이 상관없이 전국민이 대상인 지원금을 모았어요.',
    '에너지 바우처, 재난지원금 같은 보편 지원 제도를 다룹니다.',
  ],
};

const basePath = `/category/${cat}`;
const pageHref = (p) => (p === 1 ? basePath : `${basePath}/${p}`);
---

<BaseLayout title={`${catName[cat]} — 혜택PICK!!`} description={catDesc[cat].join(' ')} showAds={true}>
  <section class="cat-list" style="padding-top: 1.2rem;">
    <nav class="breadcrumb" aria-label="이동 경로">
      <a href="/">홈</a> / <span class="active">{catName[cat]}</span>
    </nav>
    <div class="cat-list-header">
      <div>
        <h1 style="font-size: 2rem; margin: 0 0 0.6rem;">{catName[cat]}</h1>
        <p style="font-size: 0.98rem; color: var(--muted); line-height: 1.7; margin: 0;">
          {catDesc[cat].map((line, i) => (<>{i > 0 && <><br class="cat-desc-br" /> </>}{line}</>))}
        </p>
      </div>
      <span class="total-badge">총 {total}건</span>
    </div>
    <style>
      @media (max-width: 640px) { .cat-desc-br { display: none; } }
    </style>

    {posts.length === 0 && (
      <p style="color: var(--muted); padding: 2rem 0;">아직 등록된 글이 없어요. 곧 채워질 예정이에요.</p>
    )}

    <div>
      {posts.map((post, i) => (
        <>
          <PostCard
            href={`/blog/${post.id.replace('.md', '')}`}
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            pubDate={post.data.pubDate}
            metric={post.data.metric}
            deadline={post.data.deadline}
          />
          {i === 3 && ADSENSE_ENABLED && <AdSenseList />}
        </>
      ))}
      {posts.length > 0 && ADSENSE_ENABLED && <AdSenseList />}
    </div>

    {totalPages > 1 && (
      <nav class="pagination" aria-label="페이지 이동">
        {page > 1 && (
          <a href={pageHref(page - 1)} class="page-arrow" aria-label="이전 페이지">‹</a>
        )}
        {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
          <a href={pageHref(p)} class="page-num" class:list={[{ active: p === page }]} aria-current={p === page ? 'page' : undefined}>{p}</a>
        ))}
        {page < totalPages && (
          <a href={pageHref(page + 1)} class="page-arrow" aria-label="다음 페이지">›</a>
        )}
      </nav>
    )}
  </section>

  {ADSENSE_ENABLED && (
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const slots = document.querySelectorAll('.cat-list .ad-slot');
      slots.forEach((slot) => {
        try { (window.adsbygoogle = window.adsbygoogle || []).push({}); } catch (e) {}

        const ins = slot.querySelector('ins.adsbygoogle');
        if (!ins) return;

        let tries = 0;
        const checker = setInterval(() => {
          tries++;
          const status = ins.getAttribute('data-ad-status');
          const iframe = ins.querySelector('iframe');

          if (status === 'unfilled') {
            slot.remove();
            clearInterval(checker);
          } else if (iframe && iframe.offsetHeight > 0) {
            clearInterval(checker);
          } else if (tries >= 12) {
            slot.remove();
            clearInterval(checker);
          }
        }, 250);
      });
    });
  </script>
  )}

  <style>
    .breadcrumb { font-size: 0.82rem; color: var(--muted); margin-bottom: 0.9rem; }
    .breadcrumb a { color: var(--muted); text-decoration: none; }
    .breadcrumb a:hover { color: var(--primary); }
    .breadcrumb .active { color: var(--primary); font-weight: 600; }
    .cat-list-header {
      display: flex; justify-content: space-between; align-items: flex-start;
      gap: 1rem; margin-bottom: 1.4rem; padding-bottom: 1.4rem; flex-wrap: wrap;
      border-bottom: 1px solid var(--line);
    }
    .total-badge {
      flex-shrink: 0; font-size: 0.85rem; font-weight: 700; color: var(--accent);
      background: var(--color-bg-soft); padding: 0.4rem 0.9rem; border-radius: 999px;
    }

    .pagination { display: flex; justify-content: center; align-items: center; gap: 0.4rem; margin-top: 2rem; }
    .page-num, .page-arrow {
      display: inline-flex; align-items: center; justify-content: center;
      width: 34px; height: 34px; border-radius: 8px;
      font-size: 0.85rem; font-weight: 600; color: var(--muted);
      text-decoration: none; border: 1px solid transparent;
    }
    .page-num:hover, .page-arrow:hover { border-color: var(--line); color: var(--primary); }
    .page-num.active { background: var(--primary); color: #fff; }
    .page-arrow { border-color: var(--line); font-size: 1.1rem; }
  </style>
</BaseLayout>
