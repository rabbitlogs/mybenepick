---
import BaseLayout from './BaseLayout.astro';
import AdSense from '../components/AdSense.astro';
import { CATEGORY_NAMES } from '../data/categories.js';

// ⚠️ BaseLayout.astro의 ADSENSE_ENABLED와 함께 켜고 끄세요.
// false인 동안은 광고 슬롯 마크업 자체를 본문에 넣지 않습니다(빈 <ins> 태그 노출 방지).
const ADSENSE_ENABLED = false;

const { title, description, pubDate, updatedDate, category, tags = [], slug, thumbnail, relatedPosts = [], deadline } = Astro.props;

const catName = CATEGORY_NAMES;
const dateStr = new Date(pubDate).toLocaleDateString('ko-KR', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const updatedDateStr = updatedDate
  ? new Date(updatedDate).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

// 읽는 시간: 본문(마크다운 원문) 글자수 기준 분당 500자로 추정, 최소 1분.
const rawBodyForReadTime = Astro.props.rawBody || '';
const charCount = rawBodyForReadTime.replace(/\s/g, '').length;
const readMinutes = Math.max(1, Math.round(charCount / 500));

// 신청 마감 여부: deadline이 날짜 문자열이 아닌 특수값("ongoing"/"budget-limited")이면
// 날짜 비교 대상에서 제외한다 — 그대로 new Date()에 넣으면 Invalid Date가 되어
// 의도치 않게 마감 처리될 수 있으므로, 반드시 날짜 파싱 전에 먼저 걸러낸다.
const NON_DATE_DEADLINE_VALUES = ['ongoing', 'budget-limited'];
const isExpired = (() => {
  if (!deadline || NON_DATE_DEADLINE_VALUES.includes(deadline)) return false;
  const startOfDay = (d) => { const x = new Date(d); x.setHours(0, 0, 0, 0); return x; };
  return startOfDay(new Date()) > startOfDay(deadline);
})();
const deadlineDateStr = deadline && !NON_DATE_DEADLINE_VALUES.includes(deadline)
  ? new Date(deadline).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
// 예산·인원 캡이 있어 소진 시 조기 마감될 수 있는 글. 실시간 소진 여부는 판별하지 않고,
// 이 값이 붙은 글에는 안내를 상시·고정으로 노출한다(6-6 참고).
const isBudgetLimited = deadline === 'budget-limited';

// JSON-LD (Article 구조화 데이터)
const siteUrl = 'https://mybenepick.com';
const pageUrl = siteUrl + '/blog/' + slug;
const ogImage = thumbnail ? siteUrl + thumbnail : siteUrl + '/og-thumbnail.jpg';
const isoDate = new Date(pubDate).toISOString();
const isoModifiedDate = updatedDate ? new Date(updatedDate).toISOString() : isoDate;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: ogImage,
  datePublished: isoDate,
  dateModified: isoModifiedDate,
  author: {
    '@type': 'Organization',
    name: '혜택PICK!!',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: '혜택PICK!!',
    logo: {
      '@type': 'ImageObject',
      url: siteUrl + '/logo-mark.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
};

// FAQPage JSON-LD: 본문 마크다운 원문에서 "Q. ~" / "A. ~" 쌍을 추출한다.
// 마크다운 작성 규칙(글쓰기가이드 3장): **Q. 질문** 다음 줄에 A. 답변.
// 페이지(예: src/pages/blog/[slug].astro)에서 콘텐츠 컬렉션 entry의 body 원문을
// rawBody prop으로 함께 넘겨줘야 한다. 넘어오지 않으면 FAQ 스키마는 조용히 생략된다.
const rawBody = Astro.props.rawBody || '';
const faqPattern = /\*\*Q\.\s*([^\*]+?)\*\*\s*\n+A\.\s*([^\n]+)/g;
const faqEntities = [];
let faqMatch;
while ((faqMatch = faqPattern.exec(rawBody)) !== null) {
  faqEntities.push({
    '@type': 'Question',
    name: faqMatch[1].trim(),
    acceptedAnswer: {
      '@type': 'Answer',
      text: faqMatch[2].trim(),
    },
  });
}

const faqJsonLd = faqEntities.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqEntities,
} : null;
---

<BaseLayout title={title} description={description} showAds={true} image={ogImage} article={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {faqJsonLd && (
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  )}
  <div class="reading-progress" aria-hidden="true">
    <div class="reading-progress-bar"></div>
  </div>
  <div class="post-grid">
    <article class="post">
      <nav class="breadcrumb" aria-label="이동 경로">
        <a href="/">홈</a> / <a href={`/category/${category}`}>{catName[category]}</a> / <span class="active">{title}</span>
      </nav>
      <div class="post-meta">
        <span class="cat">{catName[category]}</span>
        <span class="date">{dateStr}</span>
        <span class="read-time">· 읽는 시간 {readMinutes}분</span>
        {updatedDateStr && <span class="updated">· {updatedDateStr} 수정</span>}
      </div>
      <h1>{title}</h1>
      <p class="subtitle">{description}</p>

      {isExpired && (
        <div class="deadline-banner" role="note">
          <span class="deadline-banner-icon">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
          </span>
          <span class="deadline-banner-text">
            <strong>이 신청 기간은 종료됐어요{deadlineDateStr && ` (${deadlineDateStr} 마감)`}.</strong>
            다음 회차 일정은 공식 채널에서 다시 확인해주세요.
          </span>
        </div>
      )}

      {isBudgetLimited && (
        <div class="budget-banner" role="note">
          <span class="budget-banner-icon">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
          </span>
          <span class="budget-banner-text">
            <strong>예산 소진 시 조기 마감될 수 있어요.</strong>
            신청 전 최신 접수 상태를 공식 채널에서 확인해주세요.
          </span>
        </div>
      )}

      <div class="prose">
        <slot />
      </div>

      {tags && tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}

      {relatedPosts && relatedPosts.length > 0 && (
        <section class="related-posts">
          <h2 class="related-title">더 읽어보기</h2>
          <div class="related-grid">
            {relatedPosts.map((rp) => (
              <a href={rp.href} class="related-card">
                <span class="related-cat-badge" data-cat={rp.category}>{catName[rp.category]}</span>
                <p class="related-card-title">{rp.title}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!--
        데스크톱(961px 이상)에서는 본문 안의 목차([[TOC]] 위치)를 오른쪽 sticky 사이드바로 옮긴다.
        모바일/좁은 화면에서는 원래 자리(본문 최상단)에 그대로 둔다.
        리사이즈로 브레이크포인트를 넘나들 때도 다시 계산해서 옮긴다.
      -->
      <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
          const toc = document.querySelector('[data-toc-root]');
          const sidebar = document.querySelector('[data-toc-sidebar]');
          const grid = document.querySelector('.post-grid');
          if (!toc || !sidebar || !grid) return;

          const originalParent = toc.parentElement;
          const originalNextSibling = toc.nextSibling;
          const mql = window.matchMedia('(min-width: 961px)');

          const place = () => {
            if (mql.matches) {
              if (toc.parentElement !== sidebar) sidebar.appendChild(toc);
              grid.setAttribute('data-toc-moved', '');
            } else {
              if (toc.parentElement !== originalParent) {
                originalParent.insertBefore(toc, originalNextSibling);
              }
              grid.removeAttribute('data-toc-moved');
            }
          };

          place();
          mql.addEventListener('change', place);
        });
      </script>

      <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
        // 본문(.prose) 안의 링크는 전부 새 탭으로 연다.
        // (내부 추천글 링크는 이제 본문 밖 "더 읽어보기" 섹션에서 자동 생성되므로,
        //  본문 안에는 외부 공식 출처 링크만 남는다.)
        const prose = document.querySelector('.prose');
        if (!prose) return;

        prose.querySelectorAll('a[href]').forEach((a) => {
          const href = a.getAttribute('href') || '';
          if (href.startsWith('#')) return;
          if (a.target === '_blank') return;
          a.setAttribute('target', '_blank');
          a.setAttribute('rel', 'noopener noreferrer');
        });
      });
    </script>

    <!-- 읽기 진행바 스크립트: article(.post) 기준 스크롤 진행률을 0~100%로 계산 (rabbit-logs와 동일 로직) -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const bar = document.querySelector('.reading-progress-bar');
        const article = document.querySelector('.post');
        if (!bar || !article) return;

        let ticking = false;
        const update = () => {
          ticking = false;
          const rect = article.getBoundingClientRect();
          const articleTop = rect.top + window.scrollY;
          const articleHeight = article.offsetHeight;
          const viewportH = window.innerHeight;

          const scrolled = window.scrollY - articleTop + viewportH * 0.4;
          const total = Math.max(articleHeight - viewportH * 0.4, 1);
          const pct = Math.min(100, Math.max(0, (scrolled / total) * 100));
          bar.style.width = pct + '%';
        };

        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(update);
            ticking = true;
          }
        }, { passive: true });
        window.addEventListener('resize', update);
        update();
      });
    </script>

    <!--
      목차 스크롤스파이: 현재 읽고 있는 섹션의 목차 항목을 강조하고,
      왼쪽 진행바(.toc-progress)를 그만큼 채운다.
      h2/h3 헤딩이 뷰포트 상단 근처(scroll-margin-top 부근)를 지나는 시점을 기준으로 판정한다.
    -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const tocRoot = document.querySelector('[data-toc-root]');
        if (!tocRoot) return;

        const tocItems = Array.from(tocRoot.querySelectorAll('[data-toc-target]'));
        const progressBar = tocRoot.querySelector('[data-toc-progress]');
        if (tocItems.length === 0) return;

        const headings = tocItems
          .map((item) => {
            const slug = item.getAttribute('data-toc-target');
            const heading = document.getElementById(slug);
            return heading ? { item, heading, slug } : null;
          })
          .filter(Boolean);

        if (headings.length === 0) return;

        let activeIndex = 0;

        const setActive = (index) => {
          if (index === activeIndex && tocItems[index]?.classList.contains('is-active')) return;
          activeIndex = index;
          tocItems.forEach((item, i) => item.classList.toggle('is-active', i === index));
          if (progressBar) {
            const ratio = headings.length <= 1 ? 1 : index / (headings.length - 1);
            progressBar.style.height = Math.round(ratio * 100) + '%';
          }
        };

        const updateActiveByScroll = () => {
          const triggerLine = window.innerHeight * 0.28;
          let current = 0;
          for (let i = 0; i < headings.length; i++) {
            const rect = headings[i].heading.getBoundingClientRect();
            if (rect.top <= triggerLine) current = i;
            else break;
          }
          setActive(current);
        };

        let ticking = false;
        window.addEventListener('scroll', () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            updateActiveByScroll();
            ticking = false;
          });
        }, { passive: true });

        updateActiveByScroll();
      });
    </script>

    <!--
      광고 배치 (혜택PICK-글쓰기가이드 15장 결론 반영):
        - 기본 2개: 3줄 요약(summary-box 또는 toc) 직후 / 태그(FAQ 다음) 뒤
        - 표(table)가 본문에 있으면 표 다음에 1개 추가해 최대 3개
      ⚠️ 애드센스 승인 전에는 ADSENSE_ENABLED=false라 아예 렌더링 안 됨.
    -->
    {ADSENSE_ENABLED && <template id="ad-template"><AdSense /></template>}

    {ADSENSE_ENABLED && (
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const article = document.querySelector('.post');
        const prose = document.querySelector('.prose');
        const tags = document.querySelector('.post-tags');
        const tpl = document.getElementById('ad-template');
        if (!article || !prose || !tpl) return;

        const makeAd = () => tpl.content.firstElementChild.cloneNode(true);
        const placed = [];

        const insertAfter = (node) => {
          const ad = makeAd();
          node.parentNode.insertBefore(ad, node.nextSibling);
          placed.push(ad);
        };
        const appendAfterTags = () => {
          const ad = makeAd();
          ad.classList.add('ad-last');
          if (tags) tags.insertAdjacentElement('afterend', ad);
          else article.appendChild(ad);
          placed.push(ad);
        };

        // 1) 3줄 요약(toc 박스) 직후 — TOC가 없는 짧은 글은 첫 summary-box 직전으로 대체
        const toc = prose.querySelector('.toc');
        const firstSummary = prose.querySelector('.summary-box');
        if (toc) {
          insertAfter(toc);
        } else if (firstSummary) {
          insertAfter(firstSummary.previousElementSibling || firstSummary);
        }

        // 2) 표가 있으면 표 다음에 1개 추가 (조건 섹션 진입 전)
        const table = prose.querySelector('table');
        if (table) insertAfter(table);

        // 3) FAQ 다음, "더 읽어보기" 전 (태그 뒤)
        appendAfterTags();

        placed.forEach(() => {
          try { (window.adsbygoogle = window.adsbygoogle || []).push({}); } catch (e) {}
        });

        placed.forEach((slot) => {
          const ins = slot.querySelector('ins.adsbygoogle');
          if (!ins) return;

          let tries = 0;
          const checker = setInterval(() => {
            tries++;
            const status = ins.getAttribute('data-ad-status');
            const iframe = ins.querySelector('iframe');

            if (status === 'unfilled') {
              slot.remove();
              clearInterval(checker);
            } else if (iframe && iframe.offsetHeight > 0) {
              clearInterval(checker);
            } else if (tries >= 12) {
              slot.remove();
              clearInterval(checker);
            }
          }, 250);
        });
      });
    </script>
    )}

    <!-- 라이트박스: 본문(.prose) 안의 이미지를 클릭하면 확대 팝업으로 보여준다. -->
    <div id="lightbox" class="lightbox" hidden>
      <button type="button" class="lightbox-close" aria-label="닫기">✕</button>
      <img class="lightbox-img" src="" alt="" />
      <p class="lightbox-caption"></p>
    </div>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const prose = document.querySelector('.prose');
        const lightbox = document.getElementById('lightbox');
        if (!prose || !lightbox) return;

        const lbImg = lightbox.querySelector('.lightbox-img');
        const lbCaption = lightbox.querySelector('.lightbox-caption');
        const lbClose = lightbox.querySelector('.lightbox-close');
        let lastFocused = null;

        const openLightbox = (img) => {
          lastFocused = document.activeElement;
          lbImg.src = img.currentSrc || img.src;
          lbImg.alt = img.alt || '';
          if (img.alt) {
            lbCaption.textContent = img.alt;
            lbCaption.hidden = false;
          } else {
            lbCaption.textContent = '';
            lbCaption.hidden = true;
          }
          lightbox.hidden = false;
          document.body.style.overflow = 'hidden';
          lbClose.focus();
        };

        const closeLightbox = () => {
          lightbox.hidden = true;
          lbImg.src = '';
          document.body.style.overflow = '';
          if (lastFocused) lastFocused.focus();
        };

        prose.querySelectorAll('img').forEach((img) => {
          img.classList.add('lightbox-trigger');

          const wrap = document.createElement('span');
          wrap.className = 'lightbox-zoom-wrap';
          wrap.tabIndex = 0;
          wrap.setAttribute('role', 'button');
          wrap.setAttribute('aria-label', '이미지 확대');
          img.parentNode.insertBefore(wrap, img);
          wrap.appendChild(img);

          wrap.addEventListener('click', () => openLightbox(img));
          wrap.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              openLightbox(img);
            }
          });
        });

        lbClose.addEventListener('click', closeLightbox);
        lightbox.addEventListener('click', (e) => {
          if (e.target === lightbox) closeLightbox();
        });
        document.addEventListener('keydown', (e) => {
          if (!lightbox.hidden && e.key === 'Escape') closeLightbox();
        });
      });
    </script>
  </article>

    <aside class="post-sidebar" data-toc-sidebar aria-label="목차 사이드바"></aside>
  </div>

  <style is:global>
    /* 읽기 진행바: 화면 최상단 고정, 헤더보다 위 레이어 (rabbit-logs와 동일 구조: 트랙 + 바 이중 div) */
    .reading-progress {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      height: 3px; background: transparent;
    }
    .reading-progress-bar {
      height: 100%; width: 0%;
      background: var(--accent);
      transition: width 0.1s linear;
    }
    @media (max-width: 640px) {
      .reading-progress { height: 2.5px; }
      .reading-progress-bar { background: #f59e0b; }
    }
  </style>

  <style>
    .post-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      align-items: start;
    }
    .post { padding: 2.5rem 0; min-width: 0; }
    .post-sidebar { display: none; }

    /* 데스크톱: 본문(720px 상당) + 목차 사이드바 2컬럼. 사이드바는 스크롤해도 화면에 고정. */
    @media (min-width: 961px) {
      .post-grid {
        grid-template-columns: minmax(0, 1fr) 240px;
        gap: 2.5rem;
      }
      .post-sidebar {
        display: block;
        position: sticky;
        top: 5.5rem;
        max-height: calc(100vh - 7rem);
        overflow-y: auto;
        padding-top: 2.5rem;
      }
      .post-sidebar::-webkit-scrollbar { width: 4px; }
      .post-sidebar::-webkit-scrollbar-thumb { background: var(--line); border-radius: 4px; }
      /* 목차가 사이드바로 옮겨지기 전(JS 실행 전) 잠깐 본문에 보이다 사라지는 깜빡임 방지 */
      .post-grid[data-toc-moved] .prose > .toc { display: none; }
    }
  </style>

  <!--
    사이드바 안(폭 240px)에서는 목차를 좀 더 컴팩트하게 보여준다.
    .toc는 마크다운이 생성하는 순수 HTML이라 Astro의 컴포넌트 스코프가 적용되지 않으므로
    is:global로 명시해 확실히 전역 적용되게 한다.
  -->
  <style is:global>
    @media (min-width: 961px) {
      .post-sidebar .toc {
        margin: 0;
        box-shadow: none;
        border-radius: 10px;
        font-size: 14px;
      }
      .post-sidebar .toc-header { padding: 0.7rem 0.9rem; }
      .post-sidebar .toc-hint { display: none; }
      .post-sidebar .toc-body { padding: 0.5rem 0.9rem 0.5rem 0; }
      .post-sidebar .toc-track { left: 0.9rem; }
      .post-sidebar .toc-progress { left: 0.9rem; }
      .post-sidebar .toc-item { padding: 0.4rem 0.9rem 0.4rem 1.9rem; }
      .post-sidebar .toc-item::before { left: 0.58rem; top: 0.72rem; width: 8px; height: 8px; }
      .post-sidebar .toc-item.sub { padding-left: 2.6rem; }
      .post-sidebar .toc-item.sub::before { left: 0.73rem; top: 0.77rem; }
    }
  </style>

  <style>
    .breadcrumb { font-size: 0.82rem; color: var(--muted); margin-bottom: 1rem; }
    .breadcrumb a { color: var(--muted); text-decoration: none; }
    .breadcrumb a:hover { color: var(--primary); }
    .breadcrumb .active {
      color: var(--primary); font-weight: 600;
      display: inline-block; max-width: 320px; overflow: hidden;
      text-overflow: ellipsis; white-space: nowrap; vertical-align: bottom;
    }
    .post-meta { display: flex; gap: 0.75rem; align-items: center; font-size: 0.85rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .cat { color: var(--accent); font-weight: 700; }
    .date { color: var(--muted); }
    .read-time { color: var(--muted); }
    .updated { color: var(--muted); }
    .post h1 {
      font-size: 2rem; font-weight: 800; line-height: 1.3; margin: 0 0 0.6rem;
      letter-spacing: -0.03em;
    }
    .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 2rem 0 0.5rem; }
    .post-tags .tag {
      font-size: 0.85rem; color: var(--primary); background: rgba(30, 58, 95, 0.06);
      border: 1px solid rgba(30, 58, 95, 0.16); border-radius: 999px; padding: 0.25rem 0.75rem;
    }
    .related-posts { margin-top: 2.8rem; padding-top: 1.8rem; border-top: 1px solid var(--line); }
    .related-title {
      font-weight: 800; font-size: 1.1rem; color: var(--muted);
      text-transform: uppercase; letter-spacing: 0.08em;
      border-bottom: 2px solid var(--primary); padding-bottom: 0.5rem;
      display: inline-block; margin: 0 0 1rem;
    }
    .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; }
    .related-card {
      display: block; text-decoration: none;
      padding: 1rem 1.1rem; border: 1px solid var(--line); border-radius: 10px;
      transition: border-color 0.15s, transform 0.15s;
    }
    .related-card:hover { border-color: var(--primary); transform: translateY(-2px); }
    .related-cat-badge {
      display: inline-block; font-size: 0.7rem; font-weight: 700;
      padding: 0.16rem 0.5rem; border-radius: 20px;
      background: var(--color-bg-soft); color: var(--primary);
      margin-bottom: 0.5rem;
    }
    .related-cat-badge[data-cat="parenting"] { background: #fce7f3; color: #9d174d; }
    .related-cat-badge[data-cat="senior"] { background: #ede9fe; color: #5b21b6; }
    .related-cat-badge[data-cat="housing"] { background: #dcfce7; color: #166534; }
    .related-cat-badge[data-cat="youth"] { background: #dbeafe; color: #1e40af; }
    .related-cat-badge[data-cat="job-startup"] { background: #fef3c7; color: #92400e; }
    .related-cat-badge[data-cat="common"] { background: #e0e7ff; color: #3730a3; }
    .related-cat-badge[data-cat="self-employed"] { background: #ffedd5; color: #9a3412; }
    .related-card-title {
      font-size: 0.9rem; font-weight: 700; color: var(--ink); line-height: 1.4; margin: 0;
    }
    .related-card:hover .related-card-title { color: var(--primary); }
    .subtitle {
      font-size: 1.05rem; color: var(--muted); line-height: 1.6;
      margin: 0 0 1.8rem; font-weight: 400;
    }
    .deadline-banner {
      display: flex; align-items: flex-start; gap: 0.7rem;
      background: #f9fafb; border: 1px solid #e5e7eb;
      border-radius: 10px; padding: 0.9rem 1.1rem;
      margin: 0 0 1.8rem;
    }
    .deadline-banner-icon { flex-shrink: 0; color: #6b7280; margin-top: 0.1rem; }
    .deadline-banner-text { font-size: 0.9rem; color: #4b5563; line-height: 1.6; }
    .deadline-banner-text strong { display: block; color: #374151; font-weight: 700; margin-bottom: 0.2rem; }
    .budget-banner {
      display: flex; align-items: flex-start; gap: 0.7rem;
      background: #fffbeb; border: 1px solid #fde68a;
      border-radius: 10px; padding: 0.9rem 1.1rem;
      margin: 0 0 1.8rem;
    }
    .budget-banner-icon { flex-shrink: 0; color: #b45309; margin-top: 0.1rem; }
    .budget-banner-text { font-size: 0.9rem; color: #92400e; line-height: 1.6; }
    .budget-banner-text strong { display: block; color: #78350f; font-weight: 700; margin-bottom: 0.2rem; }
    .post :global(.ad-slot.ad-last) { margin-bottom: 0; }

    @media (max-width: 640px) {
      .breadcrumb .active { max-width: 160px; }
      .related-grid { grid-template-columns: 1fr; }
    }

    .post :global(.prose .lightbox-zoom-wrap) {
      position: relative;
      display: block;
      cursor: pointer;
      border-radius: 8px;
      margin: 1.5rem auto 0.1rem;
      max-width: 100%;
    }
    .post :global(.prose .lightbox-zoom-wrap img) {
      transition: filter 0.15s;
      margin: 0;
      display: block;
    }
    .post :global(.prose .lightbox-zoom-wrap:hover img),
    .post :global(.prose .lightbox-zoom-wrap:focus-visible img) {
      filter: brightness(0.93);
    }
    .post :global(.prose .lightbox-zoom-wrap:focus-visible) {
      outline: 2px solid var(--primary);
      outline-offset: 2px;
    }
  </style>

  <style is:global>
    .lightbox {
      position: fixed; inset: 0; z-index: 999;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 0.9rem; padding: 2.5rem 1.25rem;
      background: rgba(15, 23, 36, 0.92);
      cursor: zoom-out;
    }
    .lightbox[hidden] { display: none; }
    .lightbox-img {
      max-width: 100%; max-height: 80vh;
      border-radius: 8px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.4);
      cursor: default;
    }
    .lightbox-caption {
      margin: 0; max-width: 640px;
      color: #f4ece0; font-size: 0.92rem; line-height: 1.6;
      text-align: center; cursor: default;
    }
    .lightbox-caption[hidden] { display: none; }
    .lightbox-close {
      position: absolute; top: 1.1rem; right: 1.25rem;
      width: 40px; height: 40px;
      display: inline-flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,0.1); border: none; border-radius: 999px;
      color: #fff; font-size: 1.1rem; line-height: 1; cursor: pointer;
      transition: background 0.15s;
    }
    .lightbox-close:hover { background: rgba(255,255,255,0.22); }
    .lightbox-close:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }

    @media (max-width: 640px) {
      .lightbox { padding: 1.5rem 1rem; }
      .lightbox-img { max-height: 72vh; }
      .lightbox-close { top: 0.7rem; right: 0.8rem; width: 36px; height: 36px; }
    }
  </style>
</BaseLayout>
