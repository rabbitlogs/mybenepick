---
import Search from '../components/Search.astro';

// ⚠️ 애드센스 승인 전 마스터 스위치. 승인 완료되면 true로 바꾸세요.
// (승인 심사 중에는 광고 스크립트/슬롯이 페이지에 노출되지 않는 게 안전합니다.)
const ADSENSE_ENABLED = false;

const { title, description, showAds: showAdsProp = false, image } = Astro.props;
const showAds = ADSENSE_ENABLED && showAdsProp;
const ogImageUrl = image || 'https://mybenepick.com/og-thumbnail.jpg';
const canonicalUrl = new URL(Astro.url.pathname, 'https://mybenepick.com').toString();

const nav = {
  youth: '청년', youthShort: '청년',
  jobStartup: '취업·창업', jobStartupShort: '취업창업',
  parenting: '육아·출산', parentingShort: '육아출산',
  housing: '주거', housingShort: '주거',
  selfEmployed: '소상공인', selfEmployedShort: '소상공인',
  senior: '중장년·시니어', seniorShort: '중장년',
  common: '전국민 공통', commonShort: '전국민',
  about: '소개 & 문의', privacy: '개인정보처리방침', terms: '이용약관',
};
const t = nav;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#faf8f3" />
    <meta name="naver-site-verification" content="9ab1a54b5ceb93634d63a86cd8091fb3f8cd045d" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="alternate" type="application/rss+xml" title="혜택PICK!! RSS" href="/rss.xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <!-- 다이나믹 서브셋: 페이지에 실제 쓰인 글자만 받아온다 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard-dynamic-subset.min.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard-dynamic-subset.min.css" /></noscript>
    {showAds && (
      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9488002130804570" crossorigin="anonymous"></script>
    )}
    <!-- Google tag (gtag.js) -->
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-012T7Y74XY"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-012T7Y74XY');
    </script>
    <!-- 페이지별 추가 head 태그(예: JSON-LD 구조화 데이터) -->
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a href="/" class="brand"><img src="/squirrel-logo.png" alt="" class="brand-logo" width="34" height="40" /><span class="brand-name">혜택PICK!!</span></a>
        <div class="header-actions">
          <a href="/find" class="find-btn" aria-label="나에게 맞는 혜택 찾기">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9"></circle>
              <circle cx="12" cy="12" r="5"></circle>
              <circle cx="12" cy="12" r="1.2" fill="currentColor" stroke="none"></circle>
            </svg>
          </a>
          <Search lang="ko" />
          <a href="/rss.xml" class="rss-btn" aria-label="RSS 피드">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 11a9 9 0 0 1 9 9"></path>
              <path d="M4 4a16 16 0 0 1 16 16"></path>
              <circle cx="5" cy="19" r="1.4" fill="currentColor" stroke="none"></circle>
            </svg>
          </a>
        </div>
        <nav class="nav">
          <a href="/category/youth"><span class="lbl-full">{t.youth}</span><span class="lbl-short">{t.youthShort}</span></a>
          <a href="/category/job-startup"><span class="lbl-full">{t.jobStartup}</span><span class="lbl-short">{t.jobStartupShort}</span></a>
          <a href="/category/parenting"><span class="lbl-full">{t.parenting}</span><span class="lbl-short">{t.parentingShort}</span></a>
          <a href="/category/housing"><span class="lbl-full">{t.housing}</span><span class="lbl-short">{t.housingShort}</span></a>
          <a href="/category/self-employed"><span class="lbl-full">{t.selfEmployed}</span><span class="lbl-short">{t.selfEmployedShort}</span></a>
          <a href="/category/senior"><span class="lbl-full">{t.senior}</span><span class="lbl-short">{t.seniorShort}</span></a>
          <a href="/category/common"><span class="lbl-full">{t.common}</span><span class="lbl-short">{t.commonShort}</span></a>
          <a href="/regional"><span class="lbl-full">지역별</span><span class="lbl-short">지역별</span></a>
          <a href="/about"><span class="lbl-full">{t.about}</span><span class="lbl-short">소개문의</span></a>
        </nav>
      </div>
    </header>

    <main class="wrap"><slot /></main>

    <footer class="site-footer"><div class="wrap">
      <nav class="footer-links">
        <a href="/about">{t.about}</a>
        <a href="/privacy">{t.privacy}</a>
        <a href="/terms">{t.terms}</a>
      </nav>
      <p>나에게 맞는 혜택만, PICK해서 알려드려요 · © 2026 혜택PICK!!</p>
    </div></footer>

    <style is:global>
      :root {
        --paper: #faf8f3; --ink: #20251f; --primary: #8a5a3f; --accent: #6b5133;
        --muted: #696760; --line: #e3dfd4; --color-bg-soft: #f3f0e8;
        --font-body: 'Pretendard', -apple-system, system-ui, sans-serif;
        --font-display: 'Pretendard', -apple-system, system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; background: var(--paper); color: var(--ink); font-family: var(--font-body); font-size: 17px; line-height: 1.8; -webkit-font-smoothing: antialiased; }
      .wrap { max-width: 720px; margin: 0 auto; padding: 0 1.25rem; }

      .site-header { border-bottom: 1px solid var(--line); }
      .header-inner { display: flex; align-items: center; gap: 1rem; padding: 1rem 0 0.4rem; flex-wrap: wrap; }
      .brand { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: var(--ink); margin-right: auto; order: 1; }
      .brand-logo { height: 40px; width: auto; display: block; }
      .brand-name { font-family: var(--font-display); font-weight: 800; font-size: 1.35rem; letter-spacing: -0.02em; color: var(--primary); }
      .header-actions { display: flex; align-items: center; gap: 0.5rem; order: 2; }
      .find-btn,
      .rss-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; padding: 0;
        background: none; border: none; cursor: pointer;
        color: var(--primary); border-radius: 999px;
        transition: background 0.15s;
      }
      .find-btn:hover,
      .rss-btn:hover { background: rgba(138, 90, 63,0.1); }

      .nav {
        order: 3; flex: 1 0 100%;
        display: flex; align-items: center;
        justify-content: space-between;
        padding-top: 0.5rem;
        margin-top: 0.5rem;
      }
      .nav a { text-decoration: none; color: var(--muted); font-size: 0.86rem; font-weight: 500; white-space: nowrap; }
      .nav a:hover { color: var(--primary); }
      .lbl-short { display: none; }

      @media (max-width: 640px) {
        .header-inner { gap: 0.6rem 0.5rem; }
        .brand { margin-left: 0.5rem; }
        .header-actions { margin-right: 0.5rem; }
        .nav { justify-content: space-between; gap: 0.45rem 0.2rem; flex-wrap: wrap; }
        .nav a { font-size: 0.74rem; flex: 1 1 30%; text-align: center; }
        .lbl-full { display: none; }
        .lbl-short { display: inline; }
      }

      .site-footer { margin-top: 2rem; border-top: 1px solid var(--line); padding: 2rem 0; color: var(--muted); font-size: 0.85rem; text-align: center; }
      .footer-links { display: flex; gap: 1.2rem; justify-content: center; flex-wrap: wrap; margin-bottom: 0.9rem; }
      .footer-links a { color: var(--muted); text-decoration: none; font-weight: 500; }
      .footer-links a:hover { color: var(--primary); }

      /* ── 본문(prose) ── */
      .prose { font-size: 17px; line-height: 1.85; }
      .prose p { margin: 1.15rem 0; }
      .prose h2 { font-weight: 700; font-size: 1.5rem; margin-top: 2.6rem; margin-bottom: 0.8rem; line-height: 1.35; scroll-margin-top: 1.5rem; letter-spacing: -0.01em; }
      .prose h3 { font-weight: 600; font-size: 1.2rem; margin-top: 1.8rem; margin-bottom: 0.5rem; scroll-margin-top: 1.5rem; color: var(--primary); }
      .prose h2 a, .prose h3 a { color: inherit; text-decoration: none; }
      .prose strong { font-weight: 700; }
      .prose strong.key { color: var(--primary); font-weight: 700; }

      .prose .toc { margin: 2rem 0; padding: 1.1rem 1.4rem; background: var(--color-bg-soft); border: 1px solid var(--line); border-radius: 10px; }
      .prose .toc-title { margin: 0 0 0.7rem; font-weight: 700; font-size: 1em; color: var(--primary); }
      .prose .toc ul { margin: 0; padding-left: 1.2rem; }
      .prose .toc li { margin: 0.35rem 0; font-size: 1em; line-height: 1.6; }
      .prose .toc li.sub { margin-left: 1.3rem; list-style: circle; }
      .prose .toc a { color: var(--ink); text-decoration: none; }
      .prose .toc a:hover { color: var(--accent); text-decoration: underline; }

      .prose .summary-box {
        background: var(--color-bg-soft);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 1.3rem 1.5rem;
        margin: 1.8rem 0;
        box-shadow:
          0 0.5px 1px rgba(0,0,0,0.02),
          0 2px 5px rgba(0,0,0,0.025),
          0 6px 14px rgba(0,0,0,0.02);
      }
      .prose .summary-label {
        font-size: 0.8rem; font-weight: 700; color: var(--primary);
        letter-spacing: 0.06em; text-transform: uppercase;
        margin: 0 0 0.9rem;
      }
      .prose .summary-row {
        display: flex; gap: 0.6rem; font-size: 0.98rem; line-height: 1.6;
        padding: 0.35rem 0;
        border-bottom: 1px dashed rgba(138, 90, 63, 0.15);
      }
      .prose .summary-row:last-child { border-bottom: none; }
      .prose .summary-k { color: var(--primary); font-weight: 700; flex-shrink: 0; min-width: 4.2em; }
      .prose .summary-v { color: var(--ink); }

      .prose mark.hl { background: #fbe3c3; color: inherit; padding: 0.05em 0.25em; border-radius: 3px; }
      .prose code { background: #f0e9dc; color: #b6502e; padding: 0.12em 0.4em; border-radius: 4px; font-size: 0.92em; font-family: ui-monospace, monospace; }
      .prose blockquote { margin: 1.6rem 0; padding: 1rem 1.2rem; background: var(--color-bg-soft); border-left: 4px solid var(--accent); border-radius: 0 8px 8px 0; }
      .prose blockquote p { margin: 0.4rem 0; }
      .prose blockquote p:first-child { margin-top: 0; }
      .prose blockquote p:last-child { margin-bottom: 0; }
      .prose ul, .prose ol { padding-left: 1.4rem; }
      .prose li { margin: 0.4rem 0; }
      .prose img { max-width: 100%; height: auto; border-radius: 8px; display: block; margin: 1.5rem auto 0; }

      .prose em { color: var(--muted); }
      .prose p:has(img) { margin: 1.5rem 0 1.6rem; text-align: center; }
      .prose p:has(img) img { margin-bottom: 0.1rem; }
      .prose p:has(img) em,
      .prose p:has(img) + p:has(> em:only-child) em,
      .prose table + p:has(> em:only-child) em {
        display: inline-block;
        font-size: 0.88rem;
        color: var(--muted);
      }
      .prose p:has(img) + p:has(> em:only-child),
      .prose table + p:has(> em:only-child) {
        margin: 0.4rem 0 1.6rem;
        text-align: center;
      }
      .prose a { color: var(--primary); }

      .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0 0; font-size: 0.95rem; table-layout: fixed; }
      .prose th:first-child, .prose td:first-child { width: 26%; }
      .prose th, .prose td { padding: 0.6rem 0.85rem; text-align: left; word-break: keep-all; overflow-wrap: break-word; }
      .prose tr th:not(:first-child),
      .prose tr td:not(:first-child) { border-left: 1px solid #ddd2bd; }
      .prose tbody tr { border-bottom: 1px solid #ddd2bd; }
      .prose thead th { background: var(--primary); color: #fff; font-weight: 700; }
      .prose thead tr th:not(:first-child) { border-left: 1px solid rgba(255,255,255,0.4); }
      .prose tbody tr:nth-child(even) { background: rgba(138, 90, 63, 0.04); }
      .prose tbody tr:hover { background: rgba(107, 81, 51, 0.08); }

      @media (max-width: 640px) {
        body { font-size: 16px; }
        .prose { font-size: 16px; }
        .prose table { font-size: 0.85rem; }
        .prose th, .prose td { padding: 0.5rem 0.5rem; }
      }
    </style>
  </body>
</html>
