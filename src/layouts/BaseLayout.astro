---
import Search from '../components/Search.astro';

// ⚠️ 애드센스 승인 전 마스터 스위치. 승인 완료되면 true로 바꾸세요.
// (승인 심사 중에는 광고 스크립트/슬롯이 페이지에 노출되지 않는 게 안전합니다.)
const ADSENSE_ENABLED = false;

const { title, description, showAds: showAdsProp = false, image, narrow = false, article = false } = Astro.props;
const showAds = ADSENSE_ENABLED && showAdsProp;
const ogImageUrl = image || 'https://mybenepick.com/og-thumbnail.jpg';
const canonicalUrl = new URL(Astro.url.pathname, 'https://mybenepick.com').toString();

const nav = {
  youth: '청년', youthShort: '청년',
  jobStartup: '취업·창업', jobStartupShort: '취업창업',
  parenting: '육아·출산', parentingShort: '육아출산',
  housing: '주거', housingShort: '주거',
  selfEmployed: '소상공인', selfEmployedShort: '소상공인',
  senior: '중장년·시니어', seniorShort: '중장년',
  common: '전국민 공통', commonShort: '전국민',
  about: '소개 & 문의', privacy: '개인정보처리방침', terms: '이용약관',
};
const t = nav;

// 모바일 가로 스크롤 탭에서 현재 보고 있는 카테고리를 강조하기 위한 활성 slug 계산.
// /category/{slug} 페이지면 그 slug, /regional이면 'regional', 그 외(홈/글상세 등)는 없음.
const pathname = Astro.url.pathname;
const categoryMatch = pathname.match(/^\/category\/([a-z-]+)/);
const activeNavKey = categoryMatch ? categoryMatch[1] : (pathname.startsWith('/regional') ? 'regional' : null);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1e3a5f" />
    <meta name="naver-site-verification" content="9ab1a54b5ceb93634d63a86cd8091fb3f8cd045d" />
    <meta name="google-adsense-account" content="ca-pub-9488002130804570" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="alternate" type="application/rss+xml" title="혜택PICK!! RSS" href="/rss.xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <!-- 다이나믹 서브셋: 페이지에 실제 쓰인 글자만 받아온다 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard-dynamic-subset.min.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard-dynamic-subset.min.css" /></noscript>
    {showAds && (
      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9488002130804570" crossorigin="anonymous"></script>
    )}
    <!-- Google tag (gtag.js) -->
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-012T7Y74XY"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-012T7Y74XY');
    </script>
    <!-- 페이지별 추가 head 태그(예: JSON-LD 구조화 데이터) -->
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a href="/" class="brand"><span class="brand-name">혜택<span class="brand-pick">PICK!!</span></span></a>
        <div class="header-actions">
          <a href="/find" class="find-btn" aria-label="나에게 맞는 혜택 찾기">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9"></circle>
              <circle cx="12" cy="12" r="5"></circle>
              <circle cx="12" cy="12" r="1.2" fill="currentColor" stroke="none"></circle>
            </svg>
          </a>
          <Search lang="ko" />
          <a href="/rss.xml" class="rss-btn" aria-label="RSS 피드">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 11a9 9 0 0 1 9 9"></path>
              <path d="M4 4a16 16 0 0 1 16 16"></path>
              <circle cx="5" cy="19" r="1.4" fill="currentColor" stroke="none"></circle>
            </svg>
          </a>
          <a href="/about" class="m-about-link" aria-label="소개 & 문의">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="16" x2="12" y2="12"></line>
              <line x1="12" y1="8" x2="12.01" y2="8"></line>
            </svg>
          </a>
        </div>
        <nav class="nav">
          <a href="/category/youth" data-slug="youth" class:list={[{ 'is-active': activeNavKey === 'youth' }]}><span class="lbl-full">{t.youth}</span><span class="lbl-short">{t.youthShort}</span></a>
          <a href="/category/job-startup" data-slug="job-startup" class:list={[{ 'is-active': activeNavKey === 'job-startup' }]}><span class="lbl-full">{t.jobStartup}</span><span class="lbl-short">{t.jobStartupShort}</span></a>
          <a href="/category/parenting" data-slug="parenting" class:list={[{ 'is-active': activeNavKey === 'parenting' }]}><span class="lbl-full">{t.parenting}</span><span class="lbl-short">{t.parentingShort}</span></a>
          <a href="/category/housing" data-slug="housing" class:list={[{ 'is-active': activeNavKey === 'housing' }]}><span class="lbl-full">{t.housing}</span><span class="lbl-short">{t.housingShort}</span></a>
          <a href="/category/self-employed" data-slug="self-employed" class:list={[{ 'is-active': activeNavKey === 'self-employed' }]}><span class="lbl-full">{t.selfEmployed}</span><span class="lbl-short">{t.selfEmployedShort}</span></a>
          <a href="/category/senior" data-slug="senior" class:list={[{ 'is-active': activeNavKey === 'senior' }]}><span class="lbl-full">{t.senior}</span><span class="lbl-short">{t.seniorShort}</span></a>
          <a href="/category/common" data-slug="common" class:list={[{ 'is-active': activeNavKey === 'common' }]}><span class="lbl-full">{t.common}</span><span class="lbl-short">{t.commonShort}</span></a>
          <a href="/regional" data-slug="regional" class:list={[{ 'is-active': activeNavKey === 'regional' }]}><span class="lbl-full">지역별</span><span class="lbl-short">지역별</span></a>
          <a href="/about" class="nav-about"><span class="lbl-full">{t.about}</span><span class="lbl-short">소개문의</span></a>
        </nav>
      </div>
    </header>

    <main class={article ? 'wrap-article' : narrow ? 'wrap-narrow' : 'wrap'}><slot /></main>

    <footer class="site-footer"><div class="wrap">
      <nav class="footer-links">
        <a href="/about">{t.about}</a>
        <a href="/privacy">{t.privacy}</a>
        <a href="/terms">{t.terms}</a>
      </nav>
      <p>나에게 맞는 혜택만, PICK해서 알려드려요 · © 2026 혜택PICK!!</p>
    </div></footer>

    <style is:global>
      :root {
        --paper: #f7f9fc; --ink: #17263a; --primary: #1e3a5f; --accent: #2563eb;
        --muted: #5b6b7f; --line: #dce3ec; --color-bg-soft: #eef2f8;
        --footer-bg: #0f2744; --footer-ink: #cbd8ea; --footer-muted: #7e94ac;
        --font-body: 'Pretendard', -apple-system, system-ui, sans-serif;
        --font-display: 'Pretendard', -apple-system, system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; background: var(--paper); color: var(--ink); font-family: var(--font-body); font-size: 17px; line-height: 1.8; -webkit-font-smoothing: antialiased; }
      .wrap { max-width: 1080px; margin: 0 auto; padding: 0 1.25rem; }
      /* 글 상세 본문은 읽기 편한 폭(720px)을 유지 — PostLayout에서 이 클래스를 사용 */
      .wrap-narrow { max-width: 720px; margin: 0 auto; padding: 0 1.25rem; }
      /* 글 상세 전용: 본문(720px, 읽기 폭 유지) + 목차 사이드바를 담는 폭 */
      .wrap-article { max-width: 1040px; margin: 0 auto; padding: 0 1.25rem; }

      .site-header { border-bottom: 1px solid var(--line); }
      .header-inner { display: flex; align-items: center; gap: 1rem; padding: 1rem 0 0.4rem; flex-wrap: wrap; }
      .brand { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: var(--ink); margin-right: auto; order: 1; }
      .brand-name { font-family: var(--font-display); font-weight: 800; font-size: 1.35rem; letter-spacing: -0.02em; color: var(--primary); }
      .brand-pick { color: var(--accent); }
      .header-actions { display: flex; align-items: center; gap: 0.5rem; order: 2; }
      .find-btn,
      .rss-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; padding: 0;
        background: none; border: none; cursor: pointer;
        color: var(--primary); border-radius: 999px;
        transition: background 0.15s;
      }
      .find-btn:hover,
      .rss-btn:hover { background: rgba(30, 58, 95, 0.08); }

      .nav {
        order: 3; flex: 1 0 100%;
        display: flex; align-items: center;
        justify-content: space-between;
        padding-top: 0.5rem;
        margin-top: 0.5rem;
      }
      .nav a { text-decoration: none; color: var(--muted); font-size: 0.86rem; font-weight: 500; white-space: nowrap; }
      .nav a:hover { color: var(--primary); }
      .nav a.is-active { color: var(--primary); font-weight: 700; }
      .lbl-short { display: none; }

      @media (max-width: 640px) {
        .header-inner { gap: 0.5rem 0.5rem; padding: 0.85rem 0 0; }
        .brand { margin-left: 0.5rem; }
        .header-actions { margin-right: 0.5rem; }

        /* 가로 스크롤 탭: 카테고리들을 한 줄로 슬라이드, "소개&문의"는 탭에서 빼고 헤더 아이콘 쪽으로 이동 */
        .nav {
          justify-content: flex-start; flex-wrap: nowrap;
          gap: 0.4rem;
          padding: 0 0.9rem 0.75rem;
          margin: 0.5rem -1.25rem 0;
          overflow-x: auto;
          scrollbar-width: none;
          -webkit-overflow-scrolling: touch;
          mask-image: linear-gradient(to right, transparent, black 12px, black calc(100% - 24px), transparent);
        }
        .nav::-webkit-scrollbar { display: none; }
        .nav a {
          flex: 0 0 auto;
          font-size: 0.83rem; font-weight: 600; color: var(--muted);
          background: var(--color-bg-soft);
          padding: 0.45rem 0.9rem;
          border-radius: 20px;
        }
        .nav a.is-active { background: var(--primary); color: #fff; }
        .nav a.nav-about { display: none; }
        .lbl-full { display: none; }
        .lbl-short { display: inline; }
      }

      .m-about-link {
        display: none;
      }
      @media (max-width: 640px) {
        .m-about-link {
          display: inline-flex; align-items: center; justify-content: center;
          width: 34px; height: 34px; border-radius: 999px;
          color: var(--primary);
        }
        .m-about-link:hover { background: rgba(30, 58, 95, 0.08); }
      }

      .site-footer { margin-top: 3rem; background: var(--footer-bg); color: var(--footer-muted); font-size: 0.85rem; text-align: center; }
      .site-footer .wrap { padding: 2.2rem 1.25rem; }
      .footer-links { display: flex; gap: 1.2rem; justify-content: center; flex-wrap: wrap; margin-bottom: 0.9rem; }
      .footer-links a { color: var(--footer-ink); text-decoration: none; font-weight: 500; }
      .footer-links a:hover { color: #fff; }
      .site-footer p { color: var(--footer-muted); }

      /* ── 본문(prose) ── */
      .prose { font-size: 17px; line-height: 1.85; }
      .prose p { margin: 1.15rem 0; }
      .prose h2 { font-weight: 700; font-size: 1.5rem; margin-top: 2.6rem; margin-bottom: 0.8rem; line-height: 1.35; scroll-margin-top: 1.5rem; letter-spacing: -0.01em; }
      .prose h2[data-num]::before {
        content: attr(data-num);
        display: inline-block;
        font-size: 0.6em;
        font-weight: 800;
        color: var(--accent);
        margin-right: 0.5rem;
        vertical-align: 0.1em;
      }
      .prose h3 { font-weight: 600; font-size: 1.2rem; margin-top: 1.8rem; margin-bottom: 0.5rem; scroll-margin-top: 1.5rem; color: var(--primary); }
      .prose h2 a, .prose h3 a { color: inherit; text-decoration: none; }
      .prose strong { font-weight: 700; }
      .prose strong.key { color: var(--primary); font-weight: 700; }

      /* ===== 목차: 스크롤스파이 + 진행바 ===== */
      /* ===== 목차: .prose 밖(사이드바)으로 옮겨져도 스타일이 유지되도록 전역 셀렉터 사용 ===== */
      .toc {
        margin: 2rem 0;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 14px;
        box-shadow: 0 4px 16px rgba(23, 38, 58, 0.06);
        overflow: hidden;
        font-size: 17px; /* .prose 밖으로 나가도 본문과 같은 기준 크기 유지 */
      }
      .toc-header {
        display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
        padding: 0.9rem 1.3rem;
        border-bottom: 1px solid var(--line);
      }
      .toc-icon {
        width: 26px; height: 26px; border-radius: 7px; flex-shrink: 0;
        background: var(--color-bg-soft); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
      }
      .toc-title { font-weight: 700; font-size: 0.95em; color: var(--primary); }
      .toc-hint { font-weight: 400; font-size: 0.78em; color: var(--muted); margin-left: auto; }
      .toc-body { position: relative; padding: 0.7rem 1.3rem 0.7rem 0; }
      .toc-track {
        position: absolute; left: 1.3rem; top: 0.35rem; bottom: 0.35rem; width: 2px;
        background: var(--line); border-radius: 2px;
      }
      .toc-progress {
        position: absolute; left: 1.3rem; top: 0.35rem; width: 2px;
        background: var(--accent); border-radius: 2px;
        height: 0%; transition: height 0.2s ease;
      }
      .toc-list { margin: 0; padding: 0; list-style: none; }
      .toc-item {
        position: relative;
        padding: 0.5rem 1.3rem 0.5rem 2.5rem;
        display: flex; align-items: baseline; gap: 0.5rem;
        font-size: 1em; line-height: 1.6;
      }
      .toc-item::before {
        content: ''; position: absolute; left: 0.98rem; top: 0.85rem;
        width: 9px; height: 9px; border-radius: 50%;
        background: #fff; border: 2px solid var(--line);
        transition: all 0.2s ease;
      }
      .toc-item.is-active::before {
        background: var(--accent); border-color: var(--accent);
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.15);
      }
      .toc-num {
        flex-shrink: 0;
        color: var(--muted);
        font-weight: 700;
        font-size: 0.85em;
        font-variant-numeric: tabular-nums;
        transition: color 0.2s;
      }
      .toc-item.is-active .toc-num { color: var(--accent); }
      .toc-item.sub {
        padding-left: 3.5rem;
        font-size: 0.88em;
      }
      .toc-item.sub::before {
        left: 1.13rem; top: 0.9rem;
        width: 5px; height: 5px; border: none; background: var(--muted);
      }
      .toc a {
        color: var(--ink); text-decoration: none;
        border-bottom: 1px dashed transparent;
        transition: color 0.15s, border-color 0.15s;
      }
      .toc a:hover { color: var(--accent); border-bottom-color: var(--accent); }
      .toc-item.is-active a { color: var(--primary); font-weight: 700; }
      .toc-item.sub a { color: var(--muted); }

      /* 사이드바 컨텍스트 전용 컴팩트 스타일은 PostLayout.astro의 <style>에서 정의한다
         (Astro의 scoped CSS 특성상, .post-sidebar는 PostLayout 소유 클래스라
          여기 BaseLayout에서 조합 셀렉터로 오버라이드해도 적용되지 않는다). */

      @media (max-width: 640px) {
        .toc { position: static; }
      }

      .prose .summary-box {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 1.3rem 1.5rem;
        margin: 1.8rem 0;
      }
      .prose .summary-label {
        display: inline-block;
        font-size: 0.78rem; font-weight: 700; color: #fff;
        letter-spacing: 0.03em;
        background: var(--primary);
        padding: 0.3rem 0.8rem;
        border-radius: 6px;
        margin: 0 0 1rem;
      }
      .prose .summary-row {
        display: flex; gap: 0.6rem; font-size: 0.98rem; line-height: 1.6;
        padding: 0.35rem 0;
        border-bottom: 1px dashed var(--line);
      }
      .prose .summary-row:last-child { border-bottom: none; }
      .prose .summary-k { color: var(--primary); font-weight: 700; flex-shrink: 0; min-width: 4.2em; }
      .prose .summary-v { color: var(--ink); }

      /* "A." 라벨과 답변을 2컬럼 grid로 배치한다.
         이전엔 라벨 폭을 em 단위 추정치(1.9em → 1.35em)로 고정했는데, 실제 폰트(Pretendard)의
         "A." 렌더링 폭과 추정치가 안 맞아 라벨과 답변 사이 간격이 너무 벌어지거나
         (2026-07-20 1차 확인) 반대로 붙어 보이는 문제가 반복됐다.
         grid-template-columns: max-content 1fr 이면 첫 컬럼(라벨) 폭이 실제 콘텐츠
         크기에 맞춰 브라우저가 자동으로 계산하므로, 폰트가 뭐든 항상 정확하다. */
      .prose p:has(> .faq-answer) {
        display: grid;
        grid-template-columns: max-content 1fr;
        column-gap: 0.4em;
      }
      .prose p:has(> .faq-answer) > strong {
        grid-column: 1 / -1;
      }
      .prose p:has(> .faq-answer) > br {
        display: none;
      }
      .prose .faq-answer {
        display: contents;
      }
      .prose .faq-label {
        font-weight: 700;
      }

      .prose mark.hl { background: #dbeafe; color: var(--ink); padding: 0.05em 0.25em; border-radius: 3px; }
      .prose code { background: var(--color-bg-soft); color: var(--accent); padding: 0.12em 0.4em; border-radius: 4px; font-size: 0.92em; font-family: ui-monospace, monospace; }

      /* 일반 인용구(향후 정부 발표 원문 등) — 3줄 요약과는 별개 스타일 */
      .prose blockquote { margin: 1.6rem 0; padding: 1rem 1.2rem; background: var(--color-bg-soft); border-left: 4px solid var(--accent); border-radius: 0 8px 8px 0; }
      .prose blockquote p { margin: 0.4rem 0; }
      .prose blockquote p:first-child { margin-top: 0; }
      .prose blockquote p:last-child { margin-bottom: 0; }

      /* ===== 3줄 요약: 전용 박스(remarkTldrBox가 생성) — blockquote 재활용 아님 ===== */
      .prose .tldr-box {
        position: relative;
        background: linear-gradient(135deg, #eff6ff 0%, #f7f9fc 100%);
        border: 1px solid #cfe0fb;
        border-radius: 14px;
        padding: 1.4rem 1.5rem 1.3rem 1.7rem;
        margin: 1.8rem 0;
        overflow: hidden;
      }
      .prose .tldr-box::before {
        content: ''; position: absolute; top: 0; left: 0; bottom: 0; width: 5px;
        background: var(--accent);
      }
      .prose .tldr-header { display: flex; align-items: center; gap: 0.5rem; margin: 0 0 0.9rem; }
      .prose .tldr-badge {
        display: inline-flex; align-items: center; gap: 0.35rem;
        background: var(--primary); color: #fff;
        font-size: 0.78rem; font-weight: 700;
        padding: 0.3rem 0.7rem; border-radius: 20px;
        letter-spacing: 0.01em;
      }
      .prose .tldr-list {
        list-style: none; margin: 0; padding: 0;
        display: flex; flex-direction: column; gap: 0.6rem;
      }
      .prose .tldr-list li {
        display: flex; align-items: baseline; gap: 0.6rem;
        font-size: 0.98em; line-height: 1.6; color: #1e2f47;
        margin: 0;
      }
      .prose .tldr-list li::before {
        content: '•'; color: var(--accent); font-weight: 700; font-size: 1.1em; flex-shrink: 0;
      }
      .prose .tldr-list li strong { color: var(--primary); font-weight: 700; }
      .prose ul { padding-left: 1.4rem; }
      .prose li { margin: 0.4rem 0; }

      /* 순서 목록(신청 방법 등)은 원형 배지 스타일로 렌더링.
         ⚠️ :not(.toc-list) 필수 — 모바일(961px 미만)에서는 목차(.toc-list)가
         사이드바로 옮겨지지 않고 .prose 안에 그대로 남아있는데, 이 규칙이 목차에도
         걸리면 목차 자체 스타일(.toc-item::before 작은 점)과 여기 원형 배지가
         같은 ::before 자리를 두고 충돌해 숫자가 겹쳐 보인다(2026-07-20 확인). */
      .prose ol:not(.toc-list) {
        list-style: none;
        padding-left: 0;
        counter-reset: prose-ol;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        margin: 1.2rem 0;
      }
      .prose ol:not(.toc-list) li {
        counter-increment: prose-ol;
        display: flex;
        align-items: flex-start;
        gap: 0.7rem;
        margin: 0;
        line-height: 1.7;
      }
      .prose ol:not(.toc-list) li::before {
        content: counter(prose-ol);
        flex-shrink: 0;
        width: 24px; height: 24px;
        margin-top: 0.15em;
        border-radius: 50%;
        background: var(--primary);
        color: #fff;
        font-size: 0.78rem;
        font-weight: 700;
        display: flex; align-items: center; justify-content: center;
      }
      .prose ol:not(.toc-list) li .ol-content {
        min-width: 0;
        overflow-wrap: break-word;
      }
      .prose img { max-width: 100%; height: auto; border-radius: 8px; display: block; margin: 1.5rem auto 0; }

      .prose em { color: var(--muted); }
      .prose p:has(img) { margin: 1.5rem 0 1.6rem; text-align: center; }
      .prose p:has(img) img { margin-bottom: 0.1rem; }
      .prose p:has(img) em,
      .prose p:has(img) + p:has(> em:only-child) em,
      .prose table + p:has(> em:only-child) em {
        display: inline-block;
        font-size: 0.88rem;
        color: var(--muted);
      }
      .prose p:has(img) + p:has(> em:only-child),
      .prose table + p:has(> em:only-child) {
        margin: 0.4rem 0 1.6rem;
        text-align: center;
      }
      .prose a { color: var(--primary); }

      .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0 0; font-size: 0.95rem; table-layout: fixed; }
      .prose th:first-child, .prose td:first-child { width: 26%; }
      .prose th, .prose td { padding: 0.6rem 0.85rem; text-align: left; word-break: keep-all; overflow-wrap: break-word; }
      .prose tr th:not(:first-child),
      .prose tr td:not(:first-child) { border-left: 1px solid var(--line); }
      .prose tbody tr { border-bottom: 1px solid var(--line); }
      .prose thead th { background: var(--primary); color: #fff; font-weight: 700; }
      .prose thead tr th:not(:first-child) { border-left: 1px solid rgba(255,255,255,0.35); }
      .prose tbody tr:nth-child(even) { background: rgba(30, 58, 95, 0.03); }
      .prose tbody tr:hover { background: rgba(37, 99, 235, 0.06); }

      @media (max-width: 640px) {
        body { font-size: 16px; }
        .prose { font-size: 16px; }
        .prose table { font-size: 0.85rem; }
        .prose th, .prose td { padding: 0.5rem 0.5rem; }
      }
    </style>
  </body>
</html>
